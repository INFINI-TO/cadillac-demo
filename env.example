# Cadillac demo gateway (runtime)
SESSION_SECRET=
DEMO_LOGIN_USER=cadillac
DEMO_LOGIN_PASSWORD=
# Same value as aiphotobooth INTERNAL_API_SECRET (X-Internal-Secret)
INTERNAL_API_SECRET=
# Docker DNS hostname of backend service, e.g. http://aiphotobooth-backend:8000
AIPHOTOBOOTH_INTERNAL_BASE_URL=http://aiphotobooth-backend:8000
# Public HTTPS base of the aiphotobooth API (browser loads result images / QR target)
AIPHOTOBOOTH_PUBLIC_URL=https://your-api-host.example
# Set true when served over HTTPS so session cookie is Secure
SESSION_COOKIE_SECURE=true
# Optional overrides
# PROMPTS_FILE=/app/prompts.json
# ASSETS_BASE=/app/assets
# CAPTURE_DIR=/tmp/cadillac-captures
# DIST_DIR=/app/static
